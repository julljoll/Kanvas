    "timeline_visualization_enhanced": {
      "based_on": "helper/viz_timeline.py",
      "enhancements": [
        "Mostrar eventos de transferencia como hitos",
        "Resaltar períodos críticos",
        "Indicar rupturas de cadena en rojo",
        "Mostrar custodio actual en tiempo real",
        "Exportar timeline como imagen PNG/PDF"
      ]
    },

    "validation_engine": {
      "new_module": true,
      "validations": [
        {
          "validation_id": "VAL001",
          "name": "IMEI Format Validation",
          "pattern": "^[0-9]{15}$",
          "error_message": "IMEI debe ser exactamente 15 dígitos numéricos"
        },
        {
          "validation_id": "VAL002",
          "name": "Venezuelan ID Validation",
          "patterns": {
            "cedula": "^V-[0-9]{8,9}$",
            "pasaporte": "^P[A-Z0-9]{6,9}$",
            "rif": "^[VEJPG]-[0-9]{8,9}-[0-9]$"
          },
          "error_message": "Formato de identificación venezolano inválido"
        },
        {
          "validation_id": "VAL003",
          "name": "Case Number Format",
          "pattern": "^[A-Z]{2,4}-[0-9]{4}-[0-9]{4,6}$",
          "error_message": "Formato de número de caso inválido (ej: MP-2024-12345)"
        },
        {
          "validation_id": "VAL004",
          "name": "Hash SHA256 Validation",
          "pattern": "^[a-fA-F0-9]{64}$",
          "error_message": "Hash SHA256 inválido"
        },
        {
          "validation_id": "VAL005",
          "name": "Sequential Transfer Validation",
          "logic": "transfer_date[n] >= transfer_date[n-1]",
          "error_message": "Las fechas de transferencia deben ser secuenciales"
        }
      ]
    },

    "qr_code_generator": {
      "new_module": true,
      "purpose": "Generar códigos QR para sellos de seguridad",
      "data_encoded": {
        "evidence_id": "string",
        "seal_id": "string",
        "timestamp": "datetime",
        "custodian_badge": "string",
        "verification_url": "string"
      },
      "format": "QR Code ISO/IEC 18004",
      "error_correction": "Level H (30%)",
      "print_size": "50mm x 50mm minimum"
    },

    "digital_signature_integration": {
      "new_module": true,
      "supported_methods": [
        "Firma manuscrita digitalizada (imagen PNG/JPG)",
        "Firma biométrica (tablet con stylus)",
        "Firma digital certificada (PKI)",
        "Código de autenticación personal (CAP)"
      ],
      "storage": "BLOB en base de datos con cifrado AES-256",
      "verification": "Hash de la firma almacenado para validación futura"
    }
  },

