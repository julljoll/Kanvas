{
  "project_name": "Mobile Chain of Custody System - Venezuela",
  "version": "1.0.0",
  "description": "Especificación técnica basada en la lógica de Kanvas para gestión de cadena de custodia de dispositivos móviles Android según Manual Único de Cadena de Custodia Venezolano",
  
  "base_architecture": {
    "source_project": "Kanvas",
    "core_components": [
      {
        "component": "Evidence Tracker",
        "original_location": "sod.xlsx - Sheet: Evidence Tracker",
        "purpose": "Seguimiento de evidencias digitales con hashes y notas de cadena de custodia",
        "fields": [
          "Evidence ID",
          "EvidenceType",
          "EvidenceFormat", 
          "EvidenceSource",
          "Date Requested",
          "Date Received",
          "Collected By",
          "Evidence Hash (SHA256, SHA1, MD5)",
          "Storage Location",
          "Chain of Custory Notes [CORREGIR: Chain of Custody Notes]",
          "Evidence Description",
          "Notes"
        ]
      },
      {
        "component": "System Type Manager",
        "original_location": "helper/system_type.py - class SystemTypeManager",
        "purpose": "Gestión de tipos de sistemas con iconos y colores de fallback",
        "database_table": "system_types",
        "yaml_config": "helper/system_types.yaml",
        "mobile_entry": {
          "name": "Mobile",
          "display_name": "Mobile Device",
          "category": "Client",
          "icon_filename": "mobile_icon.png",
          "fallback_color": "#00ff7f",
          "description": "Mobile phones and tablets",
          "sort_order": 18
        }
      },
      {
        "component": "Evidence Type Manager",
        "original_location": "helper/system_type.py - class EvidenceTypeManager",
        "purpose": "CRUD de tipos de evidencia personalizables",
        "database_table": "EvidenceType",
        "fields": ["id", "evidencetype", "sort_order", "source"],
        "ui_dialog": "show_add_evidence_type_dialog()"
      },
      {
        "component": "Database Utilities",
        "original_location": "helper/database_utils.py",
        "purpose": "Creación y gestión de tablas SQLite",
        "tables": [
          "tor_list",
          "EvidenceType",
          "ms_portals",
          "bookmarks",
          "evtx_id",
          "entra_appid",
          "mitre_techniques",
          "mitre_tactics",
          "system_types",
          "icon_mappings",
          "defend",
          "cisa_ran_exploit"
        ]
      },
      {
        "component": "File Locking System",
        "original_location": "kanvas.py - methods: acquire_file_lock(), release_file_lock()",
        "purpose": "Control de acceso concurrente con filelock",
        "library": "filelock.FileLock",
        "modes": ["read-write", "read-only"]
      },
      {
        "component": "Reporting Engine",
        "original_location": "helper/reporting/",
        "files": [
          "report_engine.py",
          "report_builder.py",
          "html_exporter.py",
          "visualization_generator.py"
        ],
        "purpose": "Generación de reportes HTML con visualizaciones"
      },
      {
        "component": "Timeline Visualization",
        "original_location": "helper/viz_timeline.py",
        "purpose": "Línea de tiempo cronológica de incidentes"
      },
      {
        "component": "Network Visualization",
        "original_location": "helper/viz_network.py",
        "purpose": "Mapa de red de sistemas involucrados"
      }
    ]
  },

  "venezuelan_chain_custody_requirements": {
    "legal_framework": "Manual Único de Cadena de Custodia - Venezuela",
    "authority": "Ministerio Público / CICPC / Policía Científica",
    "required_fields_mobile_device": {
      "device_identification": {
        "imei": {"type": "string", "length": 15, "required": true, "description": "International Mobile Equipment Identity"},
        "serial_number": {"type": "string", "required": true, "description": "Número de serie del fabricante"},
        "brand": {"type": "string", "required": true, "examples": ["Samsung", "Xiaomi", "Motorola", "Huawei", "Apple"]},
        "model": {"type": "string", "required": true, "examples": ["Galaxy S21", "Redmi Note 10", "Moto G Power"]},
        "android_version": {"type": "string", "required": true, "examples": ["Android 11", "Android 12", "Android 13"]},
        "security_patch_level": {"type": "date", "format": "YYYY-MM-DD", "required": false},
        "build_number": {"type": "string", "required": false}
      },
      "owner_information": {
        "full_name": {"type": "string", "required": true, "description": "Nombre completo del propietario"},
        "id_type": {"type": "enum", "values": ["Cédula", "Pasaporte", "RIF", "LE", "LM"], "required": true},
        "id_number": {"type": "string", "required": true, "description": "Número de identificación"},
        "phone_number": {"type": "string", "required": false, "description": "Número asociado al dispositivo"},
        "address": {"type": "string", "required": false, "description": "Dirección del propietario"}
      },
      "seizure_information": {
        "case_number": {"type": "string", "required": true, "description": "Número de caso o expediente fiscal"},
        "legal_basis": {"type": "enum", "values": ["Orden Judicial", "Flagrancia", "Consentimiento", "Allanamiento"], "required": true},
        "judicial_order_number": {"type": "string", "required": false, "description": "Número de orden judicial si aplica"},
        "seizure_date": {"type": "datetime", "format": "YYYY-MM-DD HH:MM:SS", "required": true},
        "seizure_time": {"type": "time", "format": "HH:MM:SS", "required": true},
        "seizure_location": {"type": "string", "required": true, "description": "Lugar geográfico exacto de incautación"},
        "seizure_reason": {"type": "text", "required": true, "description": "Motivo legal de la incautación"},
        "prosecutor_name": {"type": "string", "required": false, "description": "Nombre del fiscal asignado"},
        "prosecutor_office": {"type": "string", "required": false, "description": "Fiscalía asignada"}
      },
      "physical_condition": {
        "external_condition": {"type": "enum", "values": ["Excelente", "Bueno", "Regular", "Dañado"], "required": true},
        "screen_condition": {"type": "enum", "values": ["Intacto", "Roto", "Rayado", "Sin pantalla"], "required": true},
        "body_condition": {"type": "enum", "values": ["Intacto", "Golpes", "Arañazos", "Deformado"], "required": true},
        "ports_condition": {"type": "enum", "values": ["Funcionales", "Dañados", "Obstruidos"], "required": true},
        "power_button": {"type": "boolean", "required": true, "description": "Estado del botón de encendido"},
        "volume_buttons": {"type": "boolean", "required": true, "description": "Estado de botones de volumen"},
        "camera_condition": {"type": "enum", "values": ["Funcional", "Dañada", "No verificada"], "required": true},
        "photographic_evidence": {"type": "array", "items": "image_path", "required": true, "description": "Fotografías del estado físico"},
        "existing_seals": {"type": "text", "required": false, "description": "Sellos o precintos existentes al momento de incautación"}
      },
      "device_state_at_seizure": {
        "power_state": {"type": "enum", "values": ["Encendido", "Apagado", "Bloqueado", "Pantalla negra"], "required": true},
        "battery_level": {"type": "integer", "min": 0, "max": 100, "required": true, "description": "Porcentaje de batería"},
        "charging_state": {"type": "boolean", "required": true, "description": "Si estaba conectado a cargador"},
        "network_state": {
          "wifi_enabled": {"type": "boolean", "required": true},
          "mobile_data_enabled": {"type": "boolean", "required": true},
          "bluetooth_enabled": {"type": "boolean", "required": true},
          "gps_enabled": {"type": "boolean", "required": true},
          "airplane_mode": {"type": "boolean", "required": true}
        },
        "sim_cards": {
          "count": {"type": "integer", "required": true},
          "carriers": {"type": "array", "items": "string", "required": false},
          "iccid_numbers": {"type": "array", "items": "string", "required": false}
        },
        "sd_card_present": {"type": "boolean", "required": true},
        "sd_card_capacity": {"type": "string", "required": false}
      },
      "lock_information": {
        "lock_type": {"type": "enum", "values": ["Patrón", "PIN", "Contraseña", "Huella", "Reconocimiento facial", "Ninguno", "Desconocido"], "required": true},
        "unlock_provided": {"type": "boolean", "required": true, "description": "Si se proporcionó método de desbloqueo"},
        "unlock_method_obtained": {"type": "enum", "values": ["Voluntario", "Orden Judicial", "Herramienta forense", "No obtenido"], "required": true}
      },
      "initial_collector": {
        "full_name": {"type": "string", "required": true, "description": "Nombre del funcionario recolector"},
        "badge_number": {"type": "string", "required": true, "description": "Número de placa o credencial"},
        "rank": {"type": "string", "required": true, "description": "Rango o cargo"},
        "unit": {"type": "string", "required": true, "description": "Unidad o división"},
        "signature": {"type": "image_path", "required": true, "description": "Firma digitalizada"},
        "collection_date": {"type": "datetime", "format": "YYYY-MM-DD HH:MM:SS", "required": true}
      },
      "security_measures": {
        "faraday_bag_used": {"type": "boolean", "required": true, "description": "Si se usó bolsa de Faraday"},
        "faraday_bag_id": {"type": "string", "required": false, "description": "ID de la bolsa de Faraday"},
        "evidence_bag_id": {"type": "string", "required": true, "description": "ID de la bolsa de evidencia"},
        "security_seal_id": {"type": "string", "required": true, "description": "ID del sello de seguridad"},
        "seal_qr_code": {"type": "string", "required": false, "description": "Código QR del sello"},
        "anti_tampering_measures": {"type": "text", "required": true, "description": "Medidas anti-manipulación aplicadas"}
      },
      "forensic_acquisition": {
        "acquisition_required": {"type": "boolean", "required": true},
        "acquisition_date": {"type": "datetime", "format": "YYYY-MM-DD HH:MM:SS", "required": false},
        "acquisition_method": {"type": "enum", "values": ["Extracción lógica", "Extracción física", "Extracción de sistema de archivos", "Chip-off", "JTAG"], "required": false},
        "forensic_tool": {"type": "string", "required": false, "examples": ["Cellebrite UFED", "Oxygen Forensic", "MSAB XRY", "Autopsy"]},
        "tool_version": {"type": "string", "required": false},
        "examiner_name": {"type": "string", "required": false, "description": "Nombre del examinador forense"},
        "hash_before_analysis": {"type": "object", "properties": {"sha256": "string", "sha1": "string", "md5": "string"}, "required": false},
        "hash_after_analysis": {"type": "object", "properties": {"sha256": "string", "sha1": "string", "md5": "string"}, "required": false},
        "hash_verification_passed": {"type": "boolean", "required": false, "description": "Validación de integridad"}
      },
      "storage_information": {
        "storage_location": {"type": "string", "required": true, "description": "Ubicación física de almacenamiento"},
        "evidence_room": {"type": "string", "required": true, "description": "Sala de evidencia"},
        "locker_number": {"type": "string", "required": false, "description": "Número de casillero"},
        "shelf_number": {"type": "string", "required": false, "description": "Número de estante"},
        "climate_controlled": {"type": "boolean", "required": true, "description": "Si tiene control climático"},
        "access_restrictions": {"type": "text", "required": true, "description": "Restricciones de acceso"}
      }
    },

    "custody_transfer_log": {
      "description": "Registro inmutable de cada transferencia de custodia",
      "fields": {
        "transfer_id": {"type": "string", "auto_generated": true, "format": "TRF-YYYYMMDD-XXX"},
        "evidence_id": {"type": "string", "required": true, "foreign_key": "evidence.evidence_id"},
        "transfer_date": {"type": "datetime", "format": "YYYY-MM-DD HH:MM:SS", "required": true},
        "transfer_time": {"type": "time", "format": "HH:MM:SS", "required": true},
        "from_custodian": {
          "full_name": {"type": "string", "required": true},
          "badge_number": {"type": "string", "required": true},
          "unit": {"type": "string", "required": true},
          "signature": {"type": "image_path", "required": true}
        },
        "to_custodian": {
          "full_name": {"type": "string", "required": true},
          "badge_number": {"type": "string", "required": true},
          "unit": {"type": "string", "required": true},
          "signature": {"type": "image_path", "required": true}
        },
        "transfer_reason": {"type": "enum", "values": ["Análisis forense", "Presentación judicial", "Traslado a depósito", "Devolución", "Otro"], "required": true},
        "transfer_details": {"type": "text", "required": false, "description": "Detalles adicionales de la transferencia"},
        "witness_name": {"type": "string", "required": false, "description": "Nombre del testigo si aplica"},
        "witness_signature": {"type": "image_path", "required": false},
        "device_condition_at_transfer": {"type": "enum", "values": ["Igual", "Mejorado", "Deteriorado", "Modificado"], "required": true},
        "condition_notes": {"type": "text", "required": false},
        "hash_verification": {
          "performed": {"type": "boolean", "required": true},
          "sha256_before": {"type": "string", "required": false},
          "sha256_after": {"type": "string", "required": false},
          "match": {"type": "boolean", "required": false}
        },
        "authorized_by": {"type": "string", "required": false, "description": "Autoridad que autoriza la transferencia"},
        "return_date": {"type": "datetime", "format": "YYYY-MM-DD HH:MM:SS", "required": false, "description": "Fecha de retorno si es temporal"}
      }
    },

    "chain_integrity_validation": {
      "automatic_checks": [
        {
          "check_id": "CHK001",
          "name": "Hash Integrity Verification",
          "description": "Validar que los hashes coincidan antes y después de cada transferencia",
          "trigger": "on_custody_transfer",
          "action_if_failed": "Alert immediately, mark chain as broken"
        },
        {
          "check_id": "CHK002",
          "name": "Time Sequence Validation",
          "description": "Verificar que las fechas de transferencia sean cronológicamente consistentes",
          "trigger": "on_custody_transfer_entry",
          "action_if_failed": "Prevent entry, show warning"
        },
        {
          "check_id": "CHK003",
          "name": "Signature Completeness",
          "description": "Validar que todas las firmas requeridas estén presentes",
          "trigger": "on_form_submission",
          "action_if_failed": "Block submission"
        },
        {
          "check_id": "CHK004",
          "name": "Custody Gap Detection",
          "description": "Detectar períodos sin custodio asignado",
          "trigger": "periodic",
          "action_if_failed": "Generate alert report"
        },
        {
          "check_id": "CHK005",
          "name": "Seal Integrity Check",
          "description": "Verificar que los sellos de seguridad no hayan sido alterados",
          "trigger": "on_custody_transfer",
          "action_if_failed": "Require photographic evidence and justification"
        }
      ]
    }
  },

